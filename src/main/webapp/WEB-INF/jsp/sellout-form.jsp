<%@ include file="common.jspf" %><h2>新增销售单</h2><form method="post" action="${pageContext.request.contextPath}/sellouts/save"><label>销售单号</label><br><input class="readonly" value="${code}" readonly><br><label>销售日期</label><br><input class="readonly" value='<%=new java.text.SimpleDateFormat("yyyy-MM-dd").format(new java.util.Date())%>' readonly><br><label>商品编号</label><br><select name="shopCode" required><c:forEach items="${shops}" var="s"><option value="${s.shopCode}">${s.shopCode} - ${s.shopName}</option></c:forEach></select><br><label>销售数量</label><br><input name="num" type="number" min="1" required><br><label>备注</label><br><input name="memo" maxlength="20"><br><button class="btn">保存</button></form>
