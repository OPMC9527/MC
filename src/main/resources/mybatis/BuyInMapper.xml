<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd"><mapper namespace="com.example.inventory.mapper.BuyInMapper"><resultMap id="BuyInMap" type="BuyIn"><id property="buyInCode" column="sBuyInCode"/><result property="buyDate" column="uBuyDate"/><result property="shopCode" column="uShopCode"/><result property="shopName" column="uShopName"/><result property="num" column="uNum"/><result property="memo" column="uMemo"/></resultMap><select id="findAll" resultMap="BuyInMap">SELECT b.*,s.uShopName FROM uBuyIn b LEFT JOIN uShop s ON b.uShopCode=s.uShopCode ORDER BY b.sBuyInCode DESC</select><insert id="insert" parameterType="BuyIn">INSERT INTO uBuyIn(sBuyInCode,uBuyDate,uShopCode,uNum,uMemo) VALUES(#{buyInCode},#{buyDate},#{shopCode},#{num},#{memo})</insert><select id="maxCodeLike" resultType="string">SELECT MAX(sBuyInCode) FROM uBuyIn WHERE sBuyInCode LIKE CONCAT(#{prefix},'%')</select></mapper>
