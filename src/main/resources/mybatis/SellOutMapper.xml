<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd"><mapper namespace="com.example.inventory.mapper.SellOutMapper"><resultMap id="SellOutMap" type="SellOut"><id property="sellOutCode" column="sSellOutCode"/><result property="sellDate" column="uSellDate"/><result property="shopCode" column="uShopCode"/><result property="shopName" column="uShopName"/><result property="num" column="uNum"/><result property="memo" column="uMemo"/></resultMap><select id="findAll" resultMap="SellOutMap">SELECT o.*,s.uShopName FROM uSellOut o LEFT JOIN uShop s ON o.uShopCode=s.uShopCode ORDER BY o.sSellOutCode DESC</select><insert id="insert" parameterType="SellOut">INSERT INTO uSellOut(sSellOutCode,uSellDate,uShopCode,uNum,uMemo) VALUES(#{sellOutCode},#{sellDate},#{shopCode},#{num},#{memo})</insert><select id="maxCodeLike" resultType="string">SELECT MAX(sSellOutCode) FROM uSellOut WHERE sSellOutCode LIKE CONCAT(#{prefix},'%')</select></mapper>
